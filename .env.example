# ─────────────────────────────────────────────────────────────
#  English Telegram Bot — environment configuration
#  Copy this file to ".env" and fill in the real values.
#  NEVER commit the real .env file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (REQUIRED)
BOT_TOKEN=

# Google Gemini API key — used to transcribe & give feedback on
# voice (speaking) answers, and to transcribe the student's spoken
# replies in the /learn AI tutor. Optional: without it, voice answers are
# still recorded and stored for the teacher, just without instant AI feedback.
GEMINI_API=

# ── AI tutor ( /learn ) + word game ──
# Both run on Claude (Haiku 4.5). Provide ONE Claude backend — A or B. If both are
# set the order of preference is: Claude-on-AWS -> Bedrock -> Anthropic direct.
#
# Option A — Claude Platform on AWS ("Claude on AWS"). In the AWS console:
#   API keys page  -> ANTHROPIC_AWS_API_KEY (a long-term key)
#   Workspaces page -> ANTHROPIC_AWS_WORKSPACE_ID (wrkspc_...)
ANTHROPIC_AWS_API_KEY=
ANTHROPIC_AWS_WORKSPACE_ID=
AWS_REGION=us-east-1
#
# Option B — Anthropic API key direct (from https://console.anthropic.com, "sk-ant-"):
ANTHROPIC_API_KEY=
#
# The tutor also SPEAKS (voice notes) and shows vocabulary IMAGES; those reuse
# GEMINI_API above, so no other key is needed. Learner data uses the same
# Firebase as the homework bot — nothing to configure.
#
# (Optional, advanced) override the model — a good default (Haiku 4.5) is built in:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GEMINI_TTS_VOICE=Kore
# IMAGEN_IMAGE_MODEL=gemini-2.5-flash-image

# ── Word-game Mini App (Telegram Web App) ──
# Set WEBAPP_URL to enable: the bot's menu button becomes an "Open" Web App button
# and the word game launches as the Mini App. The in-process API server listens on
# WEBAPP_API_PORT (a reverse proxy like Caddy terminates TLS in front of it).
# WEBAPP_URL=https://bot.wellversed.live
# WEBAPP_ORIGIN=https://bot.wellversed.live   (defaults to WEBAPP_URL; CORS allow-origin)
# WEBAPP_API_PORT=8081

# Teacher / admin login used inside the bot to review students.
# These default to the same credentials the website uses.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=2206

# Default interface language for brand-new users: "en" or "ru".
DEFAULT_LANGUAGE=en

# Minutes before a lesson to send reminders (comma-separated). Default: 60,10
REMINDER_OFFSETS=60,10

# Also send a 09:00 (student-local) "you have a lesson today" reminder, but only
# when the lesson starts at/after 09:00. Set to false to disable. Default: true
MORNING_REMINDER=true
